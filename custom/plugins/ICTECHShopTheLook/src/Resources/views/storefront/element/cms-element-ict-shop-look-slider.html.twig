{% block element_ict_shop_look_slider %}

{% set sliderConfig = {
    navigationArrows: element.config.navigationArrows.value,
    navigationDots: element.config.navigationDots.value,
    speed: element.config.speed.value,
    autoSlide: element.config.autoSlide.value,
    autoplayTimeout: element.config.autoplayTimeout.value
} %}

{% set sliderItems = element.data.sliderItems ?? [] %}
{% set navigationCategoryId = element.config.navigationCategoryId.value ?? null %}
{% set heading = element.config.heading.value ?? null %}

<div class="ict-shop-look-slider arrows--{{ sliderConfig.navigationArrows }} dots--{{ sliderConfig.navigationDots }}" data-shop-look-slider-options='{{ sliderConfig|json_encode }}'>

    {% if heading %}
        <h2 class="ict-shop-look-slider-heading">{{ heading }}</h2>
    {% endif %}
    {% block element_ict_shop_look_slider_container %}
    <div class="ict-slider-container">
        {% if sliderItems is not empty %}
            {% for item in sliderItems %}
                {% if item.media and item.media.url %}
                    {% block element_ict_shop_look_slider_item %}
                    <div class="ict-slide">
                        {% set slideUrl = null %}
                        {% set linkType = item.linkType ?? null %}
                        {% if linkType == 'shopPage' and item.cmsPageId and navigationCategoryId %}
                            {% set slideUrl = path('frontend.ict.shop.look.page', { navigationId: navigationCategoryId, cmsPageId: item.cmsPageId }) %}
                        {% elseif linkType == 'shopPage' and item.cmsPageId %}
                            {% set slideUrl = path('frontend.ict.shop.look.page.fallback', { cmsPageId: item.cmsPageId }) %}
                        {% elseif linkType == 'seoUrl' and (item.seoUrl ?? item.url) %}
                            {% set slideUrl = item.seoUrl ?? item.url %}
                        {% elseif linkType == 'customUrl' and (item.customUrl ?? item.url) %}
                            {% set slideUrl = item.customUrl ?? item.url %}
                        {% elseif item.cmsPageId and navigationCategoryId %}
                            {% set slideUrl = path('frontend.ict.shop.look.page', { navigationId: navigationCategoryId, cmsPageId: item.cmsPageId }) %}
                        {% elseif item.cmsPageId %}
                            {% set slideUrl = path('frontend.ict.shop.look.page.fallback', { cmsPageId: item.cmsPageId }) %}
                        {% elseif item.url %}
                            {% set slideUrl = item.url %}
                        {% endif %}

                        {% if slideUrl %}
                            <a href="{{ slideUrl }}" {% if item.newTab %}target="_blank" rel="noopener"{% endif %}>
                                <img src="{{ item.media.url }}" alt="">
                            </a>
                        {% else %}
                            <span class="ict-slide-no-link" title="No link configured for this slide">
                                <img src="{{ item.media.url }}" alt="">
                            </span>
                        {% endif %}
                    </div>
                    {% endblock %}
                {% endif %}
            {% endfor %}
        {% else %}
            {% for i in 1..6 %}
                <div class="ict-slide">
                    <img src="{{ asset('bundles/administration/static/img/cms/preview_mountain_large.jpg') }}" alt="">
                </div>
            {% endfor %}
        {% endif %}
    </div>
    {% endblock %}

    {% block element_ict_shop_look_slider_navigation %}
    {% if sliderConfig.navigationArrows != 'none' %}
        <button class="ict-slider-prev" aria-label="Previous slide">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                {% if sliderConfig.navigationArrows == 'inside' %}
                    <path d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/>
                {% else %}
                    <path d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"/>
                {% endif %}
            </svg>
        </button>
        <button class="ict-slider-next" aria-label="Next slide">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                {% if sliderConfig.navigationArrows == 'inside' %}
                    <path d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"/>
                {% else %}
                    <path d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/>
                {% endif %}
            </svg>
        </button>
    {% endif %}
    {% endblock %}

    {% block element_ict_shop_look_slider_dots %}
    {% if sliderConfig.navigationDots != 'none' %}
        <div class="ict-slider-dots"></div>
    {% endif %}
    {% endblock %}

</div>

{% endblock %}
