{% block element_ict_shop_the_look_add_all_to_cart %}
{% if config.addAllToCart and hotspots|length >= 1 %}
    <div class="add-all-section">
        <form action="{{ path('frontend.checkout.line-item.add') }}" method="post" class="add-all-form" data-add-to-cart="true">
            {% set productQuantities = {} %}
            {% for hotspot in hotspots %}
                {% set pid = hotspot.product.id %}
                {% set qty = productQuantities[pid] is defined ? productQuantities[pid] + 1 : 1 %}
                {% set productQuantities = productQuantities|merge({(pid): qty}) %}
            {% endfor %}
            {% set renderedIds = [] %}
            {% for hotspot in hotspots %}
                {% set pid = hotspot.product.id %}
                {% if pid not in renderedIds %}
                    {% set renderedIds = renderedIds|merge([pid]) %}
                    {% sw_include '@ICTECHShopTheLook/storefront/component/_line-item-inputs.html.twig' with { itemId: pid, quantity: productQuantities[pid], extraClass: 'product-line-item', dataProductId: pid } %}
                    {% if hotspot.product.options %}
                        {% set optionIds = [] %}
                        {% for option in hotspot.product.options %}
                            {% set optionIds = optionIds|merge([option.id]) %}
                        {% endfor %}
                        <input type="hidden" name="lineItems[{{ pid }}][payload]" value='{{ {"options": optionIds|reduce((carry, id) => carry|merge({(id): id}), {})}|json_encode }}' class="product-line-item default-option" data-product-id="{{ pid }}">
                    {% endif %}
                {% endif %}
            {% endfor %}
            <input type="hidden" name="redirectTo" value="frontend.cart.offcanvas">
            <input type="hidden" name="redirectParameters" data-redirect-parameters="true" value="{}">
            <button type="submit" class="btn btn-primary btn-lg add-all-to-cart"
                    data-label-select="{{ 'shop-the-look.associatedProducts.selectProducts'|trans }}"
                    data-label-add="{{ 'shop-the-look.associatedProducts.addNToCart'|trans }}"
                    data-label-out-of-stock="{{ 'shop-the-look.associatedProducts.outOfStock'|trans }}"
                    data-add-all-to-cart="true">
                {{ 'shop-the-look.associatedProducts.addAllToCart'|trans }}
            </button>
        </form>
    </div>
{% endif %}
{% endblock %}
