export default "{% block swag_paypal_paymemnt_action_v2_void %}\n<sw-modal\n    variant=\"small\"\n    :title=\"$tc(`swag-paypal-payment.modal.title.void`)\"\n    @modal-close=\"closeModal\"\n>\n\n    {% block swag_paypal_paymemnt_action_v2_void_headline %}\n    <p>{{ $tc('swag-paypal-payment.voidAction.confirm.message') }}</p>\n    {% endblock %}\n\n    <template #modal-footer>\n\n        {% block swag_paypal_paymemnt_action_v2_void_cancel_button %}\n        <sw-button @click=\"closeModal\">\n            {{ $tc('global.default.no') }}\n        </sw-button>\n        {% endblock %}\n\n        {% block swag_paypal_paymemnt_action_v2_void_confirm_button %}\n        <sw-button variant=\"primary\" @click=\"voidPayment\">\n            {{ $tc('swag-paypal-payment.voidAction.confirm.button.confirm') }}\n        </sw-button>\n        {% endblock %}\n\n    </template>\n\n    <sw-loader v-if=\"isLoading\" size=\"43px\" />\n</sw-modal>\n{% endblock %}\n";