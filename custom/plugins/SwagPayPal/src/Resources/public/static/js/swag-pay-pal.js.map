export default "{% block swag_paypal_pui_details %}\n<sw-card\n    position-identifier=\"swag-paypal-pui-details\"\n    :title=\"$tc('swag-paypal-payment.puiDetails.cardTitle')\"\n>\n\n    {% block swag_paypal_pui_details_textarea %}\n    <div class=\"swag-paypal-pui-details__textarea\">\n        <b>{{ $tc('swag-paypal-payment.puiDetails.bank') }}</b> {{ bankName }}<br>\n        <b>{{ $tc('swag-paypal-payment.puiDetails.iban') }}</b> {{ iban }}<br>\n        <b>{{ $tc('swag-paypal-payment.puiDetails.bic') }}</b> {{ bic }}<br>\n        <b>{{ $tc('swag-paypal-payment.puiDetails.accountHolder') }}</b> {{ accountHolderName }}<br>\n        <b>{{ $tc('swag-paypal-payment.puiDetails.amount') }}</b> {{ amount }}<br>\n        <b>{{ $tc('swag-paypal-payment.puiDetails.reference') }}</b> {{ reference }}<br>\n    </div>\n    {% endblock %}\n\n    {% block swag_paypal_pui_details_copy_button %}\n    <sw-button\n        class=\"swag-paypal-pui-details__copy-button\"\n        variant=\"ghost\"\n        size=\"small\"\n        @click=\"onCopy\"\n    >\n        {{ $tc('swag-paypal-payment.puiDetails.buttonCopy') }}\n    </sw-button>\n    {% endblock %}\n\n</sw-card>\n{% endblock %}\n";